<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- TV features (optional, for enhanced TV app support) -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <application
        android:name="com.cinestream.CineStreamApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CineStream"
        android:usesCleartextTraffic="false">

        <activity
            android:name="com.cinestream.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CineStream"
            android:configChanges="orientation|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- TV launcher icon (for Android TV) -->
            <meta-data
                android:name="android.leanback_icon"
                android:resource="@mipmap/ic_launcher" />
        </activity>

    </application>

</manifest>
